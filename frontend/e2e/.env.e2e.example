# ── Variables de entorno para tests E2E ──────────────────────────────────────
# Copiar este archivo a e2e/.env.e2e y completar con valores reales.
# NUNCA commitear e2e/.env.e2e (está en .gitignore).

# URLs
E2E_BASE_URL=http://localhost:5173
E2E_API_URL=http://localhost:8000/api/v1

# Credenciales de Supabase (necesarias para que api.ts obtenga tokens)
E2E_SUPABASE_URL=https://<tu-proyecto>.supabase.co
E2E_SUPABASE_ANON_KEY=<tu-anon-key>

# Usuario Admin de prueba
E2E_ADMIN_EMAIL=admin@test.usc.edu.co
E2E_ADMIN_PASSWORD=test1234

# Docentes de prueba (para registrar calificaciones vía API)
E2E_DOCENTE1_EMAIL=docente1@test.usc.edu.co
E2E_DOCENTE1_PASSWORD=test1234
E2E_DOCENTE2_EMAIL=docente2@test.usc.edu.co
E2E_DOCENTE2_PASSWORD=test1234

# IDs de proyectos en estados específicos (necesarios para tests 02-04)
# Deben existir en la base de datos de prueba antes de correr los tests.
E2E_PROJECT_IDEA_ID=<uuid-de-proyecto-en-pendiente_evaluacion_idea>
E2E_PROJECT_ANTEPROYECTO_ID=<uuid-de-proyecto-en-anteproyecto_pendiente_evaluacion>
E2E_PROJECT_SUSTENTACION_ID=<uuid-de-proyecto-en-aprobado_para_sustentacion>

# ID de docente a desactivar en test 05 (usar un docente de prueba)
E2E_DOCENTE_ID_TO_DEACTIVATE=<uuid-de-docente-activo-con-proyectos-asignados>

# Credenciales de Estudiante de prueba (tests 06-*)
E2E_ESTUDIANTE_EMAIL=estudiante@test.usc.edu.co
E2E_ESTUDIANTE_PASSWORD=test1234

# IDs para tests de Estudiante
# Proyecto en idea_aprobada (para radicar anteproyecto)
E2E_PROJECT_IDEA_APROBADA_ID=<uuid-de-proyecto-en-idea_aprobada>
# Proyecto en correcciones_anteproyecto_solicitadas (para test de correcciones)
E2E_PROJECT_CORRECCIONES_ID=<uuid-de-proyecto-en-correcciones_anteproyecto_solicitadas>
# Proyecto en acta_generada (happy path)
E2E_PROJECT_ACTA_ID=<uuid-de-proyecto-en-acta_generada>
# Proyecto con jurado asignado (para test de anonimato)
E2E_PROJECT_CON_JURADO_ID=<uuid-de-proyecto-con-jurado-asignado>

# Credenciales de Docente Jurado de prueba (tests 07-*)
# (E2E_DOCENTE1_EMAIL / E2E_DOCENTE1_PASSWORD ya definidos arriba)
# Proyecto donde el docente1 es Jurado y tiene calificación pendiente
E2E_PROJECT_JURADO_CALIFICACION_ID=<uuid-de-proyecto-en-anteproyecto_pendiente_evaluacion>

# ── Tests de Diplomado tecnológico (08-*) ─────────────────────────────────────
# Proyecto de modalidad Diplomado en cualquier estado posterior a idea_aprobada.
# Debe ser de modalidad Diplomado (requires_sustentation = false).
# Usado para verificar que el flujo omite sustentación y va directo a acta.
E2E_PROJECT_DIPLOMADO_ID=<uuid-de-proyecto-modalidad-diplomado>
