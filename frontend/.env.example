# ── Variables de entorno del frontend ─────────────────────────────────────────
# Copiar este archivo a .env y completar con valores reales.
# NUNCA commitear .env (está en .gitignore).
# Las variables VITE_* son embebidas en el bundle — no incluir secretos.
# ──────────────────────────────────────────────────────────────────────────────

# URL base de la API del backend
# Desarrollo:   http://localhost:8000/api/v1
# Producción:   https://<tu-servicio>.onrender.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Supabase (valores públicos — anon key, nunca service_role_key)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
