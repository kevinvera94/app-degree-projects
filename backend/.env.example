# ── Variables de entorno del backend ──────────────────────────────────────────
# Copiar este archivo a .env y completar con valores reales.
# NUNCA commitear .env (está en .gitignore).
#
# Para generar SECRET_KEY:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ──────────────────────────────────────────────────────────────────────────────

# Base de datos
# Formato: postgresql+asyncpg://user:password@host:port/dbname
# En Supabase: usar el connection string del pooler (puerto 6543, mode=transaction)
DATABASE_URL=postgresql+asyncpg://user:password@host:6543/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Solo backend — NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Settings > API > JWT Secret en el dashboard de Supabase
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Storage ───────────────────────────────────────────────────────────────────
SUPABASE_STORAGE_BUCKET=degree-projects-docs

# ── App ───────────────────────────────────────────────────────────────────────
# development | production
APP_ENV=development
# Mínimo 32 caracteres. Cambiar obligatoriamente en producción.
SECRET_KEY=genera-uno-con-python3-c-import-secrets-print-secrets-token-hex-32

# Orígenes permitidos para CORS (CSV, sin espacios)
# En producción incluir el dominio de Vercel:
#   ALLOWED_ORIGINS=https://app-degree-projects.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ── Plazos (días hábiles) ─────────────────────────────────────────────────────
JUROR_EVALUATION_DEADLINE_DAYS=15
JUROR_SECOND_REVIEW_DEADLINE_DAYS=10
STUDENT_CORRECTION_DEADLINE_DAYS=10
# Días hábiles antes del vencimiento para enviar alerta a jurados
JUROR_EXPIRY_ALERT_DAYS=3

# ── Festivos USC ──────────────────────────────────────────────────────────────
# Ruta al JSON de festivos del calendario académico USC.
# El archivo app/data/usc_holidays.json está incluido en el repositorio y
# funciona sin configuración adicional tanto en desarrollo como en Render.
# Solo cambiar si se usa una ruta personalizada.
USC_HOLIDAYS_FILE=app/data/usc_holidays.json
